{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "办公小浣熊 Raccoon",
  "version": "0.1.0",
  "identifier": "com.raccoon.desktop",
  "build": {
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --dir ../../frontend dev",
    "beforeBuildCommand": "pnpm --dir ../../frontend build"
  },
  "app": {
    "windows": [
      {
        "title": "办公小浣熊 Raccoon",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
