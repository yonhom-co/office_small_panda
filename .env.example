# ===== 火山引擎方舟 ARK coding plan（主模型，Anthropic 兼容，原生 tool use）=====
# 实测端点：base_url + /v1/messages  （anthropic SDK 自动追加 /v1/messages）
# 详见 docs/办公小浣熊复刻计划报告.md §2.5
# 真实 key 请填入本地 .env（已被 .gitignore 忽略），切勿填真实值到此文件。

ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding
ARK_API_KEY=ark-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx-xxxx
ARK_MAX_TOKENS=8192

# 按用途选型（coding plan 网关白名单内的模型）
ARK_MODEL=glm-5.2                                  # 默认主模型
ARK_MODEL_PLAN=glm-5.2                             # 规划/深度思考
ARK_MODEL_REASON=deepseek-v4-pro-260425            # 深度推理/数据分析子代理
ARK_MODEL_CODE=doubao-seed-2-0-code-preview-260215  # 沙箱代码生成
ARK_MODEL_LITE=doubao-seed-2-0-mini-260428         # 轻任务/路由/Todo

# ===== Embedding（知识库向量化；本地 bge-m3，因 ARK 账号无可用 embedding 模型）=====
# 实测：ARK /api/v3/embeddings 的 doubao-embedding-* 均 NotFound/ModelNotOpen
# 改用本地 sentence-transformers / bge-m3 服务（见报告 §2.5 注意事项 4）
EMBED_BASE_URL=http://localhost:8080
EMBED_API_KEY=local
EMBED_MODEL=BAAI/bge-m3

# ===== 基础设施 =====
DATABASE_URL=postgresql://raccoon:raccoon@localhost:5432/raccoon
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ===== 应用 =====
APP_ENV=dev
APP_SECRET=change-me-in-prod
SANDBOX_IMAGE=raccoon-sandbox:latest
